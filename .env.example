# KeyCRM API ключ (Налаштування → Основні → API-ключ)
KEYCRM_API_KEY=your_keycrm_api_key_here

# ID статусу у воронці для "Заброньовано"
# Знайти: KeyCRM → Налаштування → Воронки → потрібний статус → скопіювати ID
KEYCRM_BOOKED_STATUS_ID=12

# ID воронки (pipeline) в KeyCRM
KEYCRM_PIPELINE_ID=3

# Ключ кастомного поля в KeyCRM для зберігання Servio booking ID
# Створити: Налаштування → Додатково → Кастомні поля → текстове поле з ключем нижче
KEYCRM_BOOKING_ID_FIELD=servio_booking_id

# Секретний токен для перевірки запитів від Servio
# Додається в URL вебхука Servio: ?secret=YOUR_TOKEN
WEBHOOK_SECRET=change_me_to_random_string
