# --- server-agent env (поставить в Railway/VPS Variables; в репозиторий НЕ коммитить реальные значения) ---

# Ключ Claude API (Anthropic). Берётся в console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — общая шина (тот же проект call-analysis-bot)
SUPABASE_URL=https://beoendcicsoorvipswmh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # service_role (секрет)

# Доступ для Supabase MCP (чтобы агент сам ходил в БД/Notion-конвейер через MCP).
# Personal access token Supabase: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Необязательное
AGENT_MODEL=claude-opus-4-8                  # модель агента
POLL_SEC=15                                  # интервал опроса очереди agent_jobs
# REPO_ROOT=/app                             # в Docker уже выставлен; локально — корень репо
